<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1A1A2E">

    <!-- Left Panel: Custom Controls List -->
    <RelativeLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.4"
        android:padding="16dp">

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_rounded_dark"
            android:contentDescription="Close" />

        <!-- Card Container -->
        <LinearLayout
            android:id="@+id/card_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/btn_close"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_card_dark"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Controls"
                android:textColor="#F5A623"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Move Row -->
            <LinearLayout
                android:id="@+id/row_move"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_move"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Move"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_move"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Move" />
            </LinearLayout>

            <!-- Aim Row -->
            <LinearLayout
                android:id="@+id/row_aim"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_aim"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Aim"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_aim"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Aim" />
            </LinearLayout>

            <!-- Fire Row -->
            <LinearLayout
                android:id="@+id/row_fire"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_fire"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fire"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_fire"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Fire" />
            </LinearLayout>

            <!-- Crouch Row -->
            <LinearLayout
                android:id="@+id/row_crouch"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_crouch"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Crouch"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_crouch"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Crouch" />
            </LinearLayout>

            <!-- Prone Row -->
            <LinearLayout
                android:id="@+id/row_prone"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="8dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_prone"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Prone"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_prone"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Prone" />
            </LinearLayout>

            <!-- Open Backpack Row -->
            <LinearLayout
                android:id="@+id/row_open_backpack"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_row_dark"
                android:layout_marginBottom="12dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_drag_handle"
                    android:tint="#888888" />

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_backpack"
                    android:tint="#FFFFFF"
                    android:layout_marginStart="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Open Backpack"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_marginStart="12dp" />

                <ImageButton
                    android:id="@+id/btn_edit_backpack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_btn_dark"
                    android:tint="#FFFFFF"
                    android:contentDescription="Edit Open Backpack" />
            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layout_empty_state"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_empty_state"
                android:visibility="visible">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_document"
                    android:tint="#888888" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No custom controls added yet."
                    android:textColor="#888888"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>
    </RelativeLayout>

    <!-- Divider (Green Line) -->
    <View
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:background="#00FF00" />

    <!-- Right Panel: Actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Info Icon -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_info"
            android:tint="#F5A623"
            android:layout_marginBottom="12dp" />

        <!-- Info Text -->
        <TextView
            android:id="@+id/tv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a control and tap the Default button to restore default settings."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- SET DEFAULT Button -->
        <Button
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SET DEFAULT"
            android:textColor="#00FF00"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_green_outline"
            android:drawableStart="@drawable/ic_reset"
            android:drawableTint="#00FF00"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- IMPORT Button -->
        <Button
            android:id="@+id/btn_import"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="IMPORT"
            android:textColor="#00BFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_blue_outline"
            android:drawableStart="@drawable/ic_download"
            android:drawableTint="#00BFFF"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- EXPORT Button -->
        <Button
            android:id="@+id/btn_export"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="EXPORT"
            android:textColor="#BF5FFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_purple_outline"
            android:drawableStart="@drawable/ic_upload"
            android:drawableTint="#BF5FFF"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- DELETE ALL Button -->
        <Button
            android:id="@+id/btn_delete_all"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="DELETE ALL"
            android:textColor="#FF4444"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_red_outline"
            android:drawableStart="@drawable/ic_delete"
            android:drawableTint="#FF4444"
            android:drawablePadding="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- File Actions Bottom Bar -->
        <LinearLayout
            android:id="@+id/layout_file_actions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_row_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file"
                android:tint="#CCCCCC" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="File Actions"
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:layout_marginStart="12dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chevron_up"
                android:tint="#CCCCCC" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
