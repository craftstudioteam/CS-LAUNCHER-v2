<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- File Actions collapsible header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/file_actions_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/_48sdp"
        android:background="#1E1E2A"
        android:paddingStart="@dimen/_12sdp"
        android:paddingEnd="@dimen/_12sdp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_file_actions_icon"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_file_document"
            app:tint="#CCCCCC"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_file_actions_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="File Actions"
            android:textColor="#CCCCCC"
            android:textSize="@dimen/_14ssp"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintStart_toEndOf="@id/iv_file_actions_icon"
            app:layout_constraintEnd_toStartOf="@id/iv_collapse_arrow"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/iv_collapse_arrow"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_expand_less"
            app:tint="#CCCCCC"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Buttons container -->
    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/_8sdp"
        android:paddingBottom="@dimen/_8sdp"
        android:spacing="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/file_actions_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- SET DEFAULT button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A2A1A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_default_icon"
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_restore"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SET DEFAULT"
                    android:textColor="#4CAF50"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- IMPORT button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_import"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0D1A2A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#2196F3"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_import_icon"
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_download"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMPORT"
                    android:textColor="#2196F3"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- EXPORT button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_export"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A1A2A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#9C27B0"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_export_icon"
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_upload"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#9C27B0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPORT"
                    android:textColor="#9C27B0"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- DELETE ALL button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_delete_all"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#2A0D0D"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#F44336"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:id="@+id/iv_delete_icon"
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_delete"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#F44336" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELETE ALL"
                    android:textColor="#F44336"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
