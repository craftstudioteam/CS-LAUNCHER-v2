    <!-- Right Panel: Actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- Info Icon -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_info"
            android:tint="#F5A623"
            android:layout_marginBottom="12dp" />

        <!-- Info Text -->
        <TextView
            android:id="@+id/tv_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set a control and tap the Default button to restore default settings."
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- SET DEFAULT Button -->
        <Button
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="SET DEFAULT"
            android:textColor="#00FF00"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_green_outline"
            android:drawableStart="@drawable/ic_reset"
            android:drawableTint="#00FF00"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- IMPORT Button -->
        <Button
            android:id="@+id/btn_import"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="IMPORT"
            android:textColor="#00BFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_blue_outline"
            android:drawableStart="@drawable/ic_download"
            android:drawableTint="#00BFFF"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- EXPORT Button -->
        <Button
            android:id="@+id/btn_export"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="EXPORT"
            android:textColor="#BF5FFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_purple_outline"
            android:drawableStart="@drawable/ic_upload"
            android:drawableTint="#BF5FFF"
            android:drawablePadding="8dp"
            android:layout_marginBottom="12dp" />

        <!-- DELETE ALL Button -->
        <Button
            android:id="@+id/btn_delete_all"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="DELETE ALL"
            android:textColor="#FF4444"
            android:textStyle="bold"
            android:textSize="15sp"
            android:background="@drawable/bg_btn_red_outline"
            android:drawableStart="@drawable/ic_delete"
            android:drawableTint="#FF4444"
            android:drawablePadding="8dp"
            android:layout_marginBottom="24dp" />

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- File Actions Bottom Bar -->
        <LinearLayout
            android:id="@+id/layout_file_actions"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_row_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_file"
                android:tint="#CCCCCC" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="File Actions"
                android:textColor="#CCCCCC"
                android:textSize="15sp"
                android:layout_marginStart="12dp" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chevron_up"
                android:tint="#CCCCCC" />
        </LinearLayout>

    </LinearLayout>

