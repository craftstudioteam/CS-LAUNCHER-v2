<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- File Actions collapsible header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/file_actions_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/_48sdp"
        android:background="#1E1E2A"
        android:paddingStart="@dimen/_12sdp"
        android:paddingEnd="@dimen/_12sdp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_file_actions_icon"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_file_document"
            app:tint="#CCCCCC"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tv_file_actions_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="File Actions"
            android:textColor="#CCCCCC"
            android:textSize="@dimen/_14ssp"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintStart_toEndOf="@id/iv_file_actions_icon"
            app:layout_constraintEnd_toStartOf="@id/iv_collapse_arrow"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/iv_collapse_arrow"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_expand_less"
            app:tint="#CCCCCC"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Buttons container -->
    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/_8sdp"
        android:paddingBottom="@dimen/_8sdp"
        app:layout_constraintTop_toBottomOf="@id/file_actions_header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--
            returnButton → SET DEFAULT
            Kotlin: returnButton.setOnClickListener { ZHTools.onBackPressed(...) }
            In this new UI, SET DEFAULT is the primary action shown visually.
            The back action is handled by btn_back in fragment_control_manager.xml.
            So returnButton here is mapped to SET DEFAULT card.
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/returnButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A2A1A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#4CAF50"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_restore"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SET DEFAULT"
                    android:textColor="#4CAF50"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!--
            addFileButton → IMPORT
            Kotlin: addFileButton.setOnClickListener { openDocumentLauncher?.launch(".json") }
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addFileButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#0D1A2A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#2196F3"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_download"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IMPORT"
                    android:textColor="#2196F3"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!--
            createFolderButton → EXPORT
            Kotlin: createFolderButton.setOnClickListener { show EditControlInfoDialog to create new control }
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/createFolderButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#1A1A2A"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#9C27B0"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_upload"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#9C27B0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CREATE NEW"
                    android:textColor="#9C27B0"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!--
            pasteButton → DELETE ALL (hidden by default, shown when clipboard has file)
            Kotlin: pasteButton.visibility = View.GONE/VISIBLE
        -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pasteButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_52sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:cardBackgroundColor="#2A0D0D"
            app:cardCornerRadius="@dimen/_10sdp"
            app:cardElevation="0dp"
            app:strokeColor="#F44336"
            app:strokeWidth="1.5dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="@dimen/_16sdp"
                android:paddingEnd="@dimen/_16sdp">

                <ImageView
                    android:layout_width="@dimen/_22sdp"
                    android:layout_height="@dimen/_22sdp"
                    android:src="@drawable/ic_paste"
                    android:layout_centerVertical="true"
                    android:layout_alignParentStart="true"
                    app:tint="#F44336" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PASTE"
                    android:textColor="#F44336"
                    android:textSize="@dimen/_13ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Search and Refresh row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_48sdp"
            android:orientation="horizontal">

            <!--
                searchButton → Search icon button
                Kotlin: searchButton.setOnClickListener { mSearchViewWrapper.setVisibility() }
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/_4sdp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A2A"
                app:cardCornerRadius="@dimen/_10sdp"
                app:cardElevation="0dp"
                app:strokeColor="#607D8B"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_search"
                        android:layout_centerInParent="true"
                        app:tint="#90A4AE" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--
                refreshButton → Refresh icon button
                Kotlin: refreshButton.setOnClickListener { controlsListViewCreator.refresh() }
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/refreshButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_4sdp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#1A1A2A"
                app:cardCornerRadius="@dimen/_10sdp"
                app:cardElevation="0dp"
                app:strokeColor="#607D8B"
                app:strokeWidth="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="@dimen/_20sdp"
                        android:layout_height="@dimen/_20sdp"
                        android:src="@drawable/ic_refresh"
                        android:layout_centerInParent="true"
                        app:tint="#90A4AE" />

                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
